List: doubly linked list

Data structure:
  list_header
  list_element

API:

// Create a list
list_header *list_create (list_header *list, ushort max,
                          char *const name, ushort flags)

// Inisert element at list tail
static inline void *list_enqueue (list_header *list, list_element *element,
                                  void *data)

// Insert element at list head
static inline void *list_requeue (list_header *list, list_element *element,
                                  void *data)

// Insert element in a sorted manner
static inline void *list_insert (list_header *list, list_element *element,
                                 void *data, list_insert_func_t func)


// Remove first element from list
static inline void *list_dequeue (list_header *list);

// Remove specified element from list
static inline void *list_remove (list_header *list, list_element *element,
                                 void *data);

// Destroy list
void list_destroy (list_header *list);


Macros:
  LIST_SIZE (list)
  LIST_EMPTY (list)
  LIST_HEAD_ELEMENT (list)
  LIST_TAIL_ELEMENT (list)
  LIST_NEXT_ELEMENT (element)
  LIST_PREV_ELEMENT (element)
  LIST_GET_DATA (element)
  FOR_ALL_ELEMENTS_IN_LIST (list, element)
  FOR_ALL_DATA_IN_LIST (list, element, data)
