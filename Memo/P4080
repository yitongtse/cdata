# To telnet to P4080 eval syste
- Old Eval board (P1, 1.5GHz):
telnet 172.22.12.13 2003
- New Eval board (P2):
telnet 172.22.12.13 2004

# Console setup
conf t
line <n>
speed 115200
parity none

# Uboot setup
Need to set up the following environment variables:
  ipaddr, netmask, gatewayip
setenv <environ-var> <value>
Need to use the 2.41.x.x lab subnet setting.

# Hit any key to stop autoboot

# Load QNX image
tftpboot 0x100000 /tftpboot/ytse/p4080ds-qnx641-instr.ifs
tftpboot 0x100000 /tftpboot/ytse/p4080ds-qnx641.ifs
tftpboot 0x100000 /tftpboot/ytse/ifs-p4080ds.raw
tftpboot 0x100000 /tftpboot/ytse/ifs-p4080ds_YT.raw
tftpboot 0x100000 /tftpboot/ytse/ifs-p4080ds_YT_tftp.raw
go 0x100000


# Network configuration
# Old P4080DS
ifconfig dsec1 172.22.12.144 netmask 255.25.255.128
route add default 172.22.12.129

# New P4080DS
#io-pkt-v4-hc -ptcpip stacksize=65536 -dp40xx 4x1g_fm2
#ip_up -pa dsec0 desc1 desc2 desc3
ifconfig dsec1 172.22.12.143 netmask 255.255.255.128
route add default 172.22.12.129
qconn

# For tftp to work
ifconfig dsec0 2.41.0.103 netmask 255.255.0.0
route add default 2.41.0.1
tftp -e 223.255.254.254 69
get ./ytse/dpaa_test

# To clean up network configuration
route delete default
ifconfig dsec1 delete

# System profiling
tracelogger -f /dev/shmem/my_trace.kev -n 64

# Application profiling
QPROF_START=1 QPROF_FILE=/tmp/bb_test2.ptrace bb_test2 &

