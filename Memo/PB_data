struct vn_mgr {
    vn_qam *qam[24];
    asiout* asi_port;
    qam_group group[6];
}

struct vn_qam {
    vn_mgr* lc_mgr;
    f_port* f_port;
}

struct f_port {
    vn_qam qam[2];
}

struct qam_group {
    f_port *port[2];
}

struct asiout {
    vn_qam *qam;
}


