# First build
ljam enxr-router-spirit-64.vm

# Rebuild
ljam enxr-router-spirit-64.pie

# Moonshine virtual platform for IOS-XR
moonshine check
moonshine boot -v1 enxr-router-spirit-64.vm
moonshine launch -v1 enxr-router-spirit-64.vm -t training/induction/shared/test/topologies/single-rp.pm
moonshine update --v1pie enxr-router-spirit-64.pie

# debugging (IOS)
cfg: logging console debugging
debug wordsmith module main verbose
undebug all

# Smart UT
smartut run -- wordsmith_engine_mut -g base_error base_mainline_topic1

smartut run -- valgrind --leak-check=full --suppressions=/pkg/etc/ws_valgrind.supp wordsmith_engine_mut -g base_error base_mainline_topic1


