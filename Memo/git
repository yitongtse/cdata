# To set up local repository
git init

# To add a new or changed file to the staging area
git add <file or dir/>

# To remove a file and also stage the removal
git rm <file>

# To check what's in staging
git status

# To get change history
git log

# To show changes not yet staged
git diff

# To show changes already staged
git diff --staged

# To show all changes from last commit (both staged and unstaged)
git diff HEAD

# To unstage a change
git reset <file>

# To revert a file to the previous committed version
# (i.e. remove all uncommitted changes)
git checkout -- <file>

# To commit changes in staging area
git commit -m "comment"

git commit -F- << EOF
? line1
? line2
EOF

# To commit all changes in tracked file
git commit -a

# To rename a file
git mv <old_file> <new_flie>

# To remove file from repository
git rm -f <file>

# To remove directory from repository
git rm -fr <file>

# To list all files in repository
git ls-tree --full-tree -r HEAD

# To clone a remote repository
git clone <link>

# Adding remote repository
git remote add origin https://github.com/path/example.git

# Push local change to remote repository
git push origin master

# Pull changes from remote repository
git pull origin master


# To pull a new branch
git branch <name>

# To list branches (with '*' on active branch)
git branch

# To swtich to different branch
git checkout <branch>

# To merge a branch into current branch
git merge <branch>

# To delete a branch
git branch -d <branch>

