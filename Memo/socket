include: sys/socket.h
library: libsocket


int socket(int domain, int type, int protocol)

- Create an endpoint for communication
- returns descriptor
- domain: communication domain, select protocol family
- type: SOCK_STREAM: sequenced, reliable, two-way communication
        SOCK_DGRAM: connectionless, unreliable datagrams
        SOCK_RAW: only to root, for internal network protocols
- protocol
- convention:
  - SOCK_STREAM: create a socket, connect() it to another socket,
                 then do read() / write(), or send() / recv().
                 When done, close() the session.
  - SOCK_DGRAM or SOCK_RAW:  just use send() and recvfrom()
             

---------------------------------

int connect(int s, const struct sockaddr * name, socklen_t namelen)

- Establish connection according to socket type of s
- Return 0 if success, -1 if error (errno set)
- s: socket descriptor
- name: socket name (for a SOCK_STREAM)
- namelen: name length in bytes
- For SOCK_DGRAM: specify the peer socket.  Can only send to or receive from
  the peer socket.  Datagram socket may connect() multiple times to
  change association.
- For SOCK_STREAM: make connection to specified socket.  Stream sockets may
  only connect() once.


---------------------------------

ssize_t send(int s, const void *msg, size_t len, int flags)

- Send a message to a CONNECTED socket
- Return number of bytes sent, or -1 if error (errno set).
- flag: MSG_OOB: process out-of-band data
        MSG_DONTROUTE: bypass routing, create direct interface


---------------------------------

ssize_t sendto(int s, const void *msg, size_t len, int flags,
               const struct sockadddr *to, socket_t tolen)

- Send a message to a socket at a specific address
- to: pointer to socketaddr object that specifies target address
- tolen: a socklen_t object that specifies the size of the to address


---------------------------------

ssize_t sendmsg(int s, const struct msghdr *msg, int flags)

- Send a message and its header to a socket


---------------------------------

ssize_t recv(int s, void *buf, size_t len, int flags)

- Receive a message from a socket
- Return number of bytes received, or -1 (errno set)
- buf: pointer to message buffer
- len: size of the buffer
- flags: MSG_OOB
         MSG_PEEK: peek at the incoming message, but do not remove message
                   from receive queue
         MSG_WAITALL: wait for full request or error
- Normally used only on a connected socket
- Normally would block waiting for message, unless the socket is unblocking


---------------------------------

ssize_t recvfrom(int s, void *buff, size_t len, int flags,
                 struct sockaddr *from, socklen_t *fromlen)

- Receive a message from the socket at the specified address
- Works no matter whether s is connection oriented or not


---------------------------------

ssize_t recvmsg(int s, struct msghdr *msg, int flags)

- Receive a message and its header from a socket,
  whether or not it is connection-oriented.

- struct msghdr {
    caddr_t msg_name;       /* optional address */
    u_int   msg_namelen;    /* size of address */
    struct  iovec *msg_iov; /* scatter/gather array */
    u_int   msg_iovlen;     /* # elements in msg_iov */
    caddr_t msg_control;    /* ancillary data, see below */
    u_int   msg_controllen; /* ancillary data buffer len */
    int     msg_flags;      /* flags on received message */
};


- struct cmsghdr {
    u_int cmsg_len;    /* data byte count, including hdr */
    int cmsg_level;    /* originating protocol */
    int cmsg_type;     /* protocol-specific type */
                       /* followed by u_char cmsg_data[]; */
};


