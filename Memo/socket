int select (int width, fd_set *readfds, fd_set *writefds, fd_set exceptfds,
            struct timeval *timeout);

- Related macros for fd_set operations:
  FD_ZERO(int fd, fd_set *fdset): initialize
  FD_SET(int fd, fd_set *fdset): add
  FD_CLR(int fd, fd_set *fdset): remove
  FD_ISSET(int fd, fd_set *fdset): membership check

- Check for files that are ready for reading or writing
- width: number of descriptors to check in the given sets
- readfds: NULL, or pointer to fd_set object that specifies the descriptors
           to check for files that are ready for reading
- writefds: ... ready for writing
- exceptsfds: ... exceptional conditional pending


---------------------------------

int bind(int s, const struct sockaddr *name, socklen_t namelen)

- Bind a name to a socket
- socket() creates a socket that only exists in a namespace (address family)
  but whith no name assigned.  bind() assigns a name to the unnamed socket.
- Note: Use bind() to assign local address.
        Use connect() to assign remote address.


---------------------------------

int listen(int s, int backlog)

- Listen from connections on a socket
- backlog: max length the queue of pending connections may grow to
- Guideline:  socket(): create socket
              listen(): indicate willingness to accept incoming connections
              accept(): accept the connection


---------------------------------

int accept(int s, struct sockaddr *addr, socklen_t *addrlen)

- Accept a connection on a socket



