tmux: Terminal mux tool

// show all current sessions
tmux ls

// create a new session
tmux new [-s <session-name>]

// attach to a session
tmux a [-t <session-name>]

// detach from existing session
tmux detach

// killing a session
tmux kill-session [-t <session-name>]

// To detach from current tmux session
Ctrb-b + d

