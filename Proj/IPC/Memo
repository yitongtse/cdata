How source port ID field is set:

ipc_get_message() calls ipc_get_message_fully_addressed() and supply the
source port id as 0!


    header->source_port = ipc_make_portid(the_zone->local_seat_addr,ipc_portid_t
o_port(source_portid));
   
    header->type_hdr.length = IPC_MESSAGE_ENCAPS_SIZE;
    header->type_hdr.type = IPC_HEADER_TYPE_MAIN;

    if (dest_port_info != NULL) {
        header->dest_port = dest_port_info->port_id;
        header->port_index = dest_port_info->port_index;
        open_port_data = ipc_get_open_port(dest_port_info->port_id);
        if (open_port_data != NULL) {
            /*
             * increment the msgs given count for this message to the dest port
             * as we give the message, also mark the msg flags as SENDER
             * side to identify where the message was requested by sender
             */
            ipss = ipc_get_port_seq_struct(open_port_data,
                                        dest_port_info->local_port_index,
                                        NULL, NULL);
            if (ipss != NULL) {
                atomic_increment(&ipss->msgs_given);
            }
            new_message->flags |= IPC_FLAG_SENDER_MSG;
        }
    } else {
        header->dest_port = 0;
        header->port_index = 0;
    }
    header->sequence = 0;
    header->type = type;
    header->size = size;
    header->flags = 0;


