Here is how rpc_reply works:

ipc_send_rpc_reply_inline () 
{
    reply_port_info->port_features = IPC_PORT_FEAT_RELIABLE |
        IPC_PORT_CALLBACK;
    reply_port_info->notify_context = NULL;
    reply_port_info->notify_callback = ipc_rpc_reply_callback;
    ipc_result = ipc_open_control_port(orig_header->source_port,
                                       reply_port_info);
}

ipc_error_code ipc_open_control_port (ipc_port_id port_id,
                                      ipc_port_info *port_info)
{
    ipc_seat dest_seat_id;
    ipc_error_code ipc_result;

    dest_seat_id = ipc_portid_to_seat(port_id);

    ipc_result = ipc_port_info_init(port_id, port_info, dest_seat_id);
    if (ipc_result != IPC_OK) {
        if (ipc_debug_ports)
            buginf("\nIPC: open control port error :%s",
                   ipc_decode_error(ipc_result));
        return (ipc_result);
    }

    port_info->port_features |= IPC_PORT_FEAT_CONTROL;

    return (ipc_result);
}

