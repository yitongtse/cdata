ipc_error_code ipc_create_named_port (char *name, ipc_port_id *port,
                                      ulong port_flags,
                                      ipc_receive_method rx_method,
                                      void *context, void *ipc_rx_handler)
{
    return ipc_create_named_port_on_zone(name, port, port_flags, rx_method,
                                         context, ipc_rx_handler,
                                         IPC_DEFAULT_ZONE);
}

ipc_error_code ipc_create_named_port_on_zone (char *name, ipc_port_id *port,
                                              ulong port_flags,
                                              ipc_receive_method rx_method,
                                              void *context,
                                              void *ipc_rx_handler,
                                              ipc_zone zone_id)
{
    return ipc_create_named_port_extended(name, port, port_flags,
                                          rx_method, context, ipc_rx_handler,
                                          NULL, NULL, zone_id, 0);
}


/*
 * ipc_create_named_port_extended()
 * Same as above function, additional arguments specify an interrupt context
 * preview function and an IPC ACK examination function respectively.
 *
 * This feature is currently(2000-03-24) only used for c5800 async data
 * flow control, but may have wider applicability
 */
ipc_error_code ipc_create_named_port_extended (char *name, ipc_port_id *port,
                                  ulong port_flags,
                                  ipc_receive_method rx_method,
                                  void *context, void *ipc_rx_handler,
                                  ipc_preview_callback ipc_preview_handler,
                                  ipc_ack_callback ipc_ack_handler,
                                  ipc_zone zone_id,
                                  ipc_mcast_appclass_type appclass)
{
    if (rx_method < IPC_QUEUE || rx_method >= IPC_RX_METHOD_LAST) {
        return (IPC_INVALID_RX_METHOD);
    }

    /*
     * Create the unique local port identifier
     */

    *port = ipc_make_portid(zone->local_seat_addr,
                            ++zone->last_port);

    /*
     * Create the database entries for mapping ports <-> names.
     */
    new_port = ipc_create_port_entry_extended(name, *port, appclass);

    /*
     * Set up the receive method stuff
     */
    switch (rx_method) {
    case IPC_QUEUE:
        ipc_set_receive_queue(new_port, (watched_queue *)ipc_rx_handler);
        break;

    case IPC_CALLBACK:
        ipc_set_receive_callback(new_port, context,
                                 (ipc_callback)ipc_rx_handler);
        break;

    case IPC_FAST_CALLBACK:
        ipc_set_receive_fast_callback(new_port, context,
                                      (ipc_callback)ipc_rx_handler);
        break;

    default:
        break;
    }

    ipc_set_callback_method(new_port, rx_method);
    ipc_set_preview_callback(new_port, ipc_preview_handler);
    ipc_set_ack_callback(new_port, ipc_ack_handler);

    return (IPC_OK);
}




/*
 * ipc_send_local()
 *
 * This is the local transmit vector.  It simply queues the message on the IPC
 * server's input queue.
 * Returns: boolean - FALSE if message sent, TRUE otherwise
 */
boolean ipc_send_local (ipc_message *message, ipc_seat_data *seat)
{
    ipc_message *dup_message;
    ipc_size message_size;
    ipc_message_header *message_header;

    // NOTE: ipc_send_local_seat() simply returns FALSE for IOS.
    //       It does something else for the ION version.
    if (ipc_send_local_seat(message, seat)) {
        return (TRUE);
    }

    dup_message = ipc_get_pak_message(message_size, NULL, 0);

    bcopy(message_header, dup_message->header,
          (message_size + message_header->type_hdr.length));

    ipc_process_message(dup_message);
    return (FALSE);
}

