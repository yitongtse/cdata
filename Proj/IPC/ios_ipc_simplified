// ipc_output()
//   Send an ipc message to the destination address by looking up the
//   destination seat and calling its output vector.
//
void ipc_output (ipc_message *message, ipc_seat_data *dest_seat)
{
    if (dest_seat && dest_seat->send_vector) {
        (*dest_seat->send_vector)(message, dest_seat)
    }
}


