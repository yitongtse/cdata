Unreliable non-blocking message send ()
{
    if (fd is not open) {
        reopen fd
    }
    if (fd is open) {
        devctl ();
    }
    return IPC_OK
}


NOTE: For local IPC, we allow only one outstanding message
      But for remote IPC, we allow to have more than one outstanding messages!

Local IPC requires two variables to keep track of sequence number:
    last_send: seq number used in last outgoing message
    last_ack: seq number last ack'ed

Remote IPC requires one more:
    last_fwd: seq number last forwarded by SM

To have a general scheme that works in both cases:
    ipc_send_message() increments last_send
    For local IPC: MsgReply() increments last_fwd and last_ack
    For remote IPC: MsgReply() from SM increments last_fwd
                    ACK forwarded by SM increments last_ack
    API should send the message if seq_no == last_fwd + 1
    Otherwise queue the message on tx_que
          

Reliable non-blocking message send ()
{
    if seq_no is the next expected {
        if (fd is not open) {
            reopen fd
        }
        if (fd is open) {
            err = devctl(...,  &status);
            if (err == EOK) {
                if (status == IPC_REPLY_ACK) {
                    return IPC_OK;
                }
            }
        }
    }

    put message on tx_que
    if (timer not armed) {
        arm timer
    }
    retrun IPC_OK;
}


Reliable blocking message send ()
{
    for (i=0; i<retry_cnt; i++) {
        if (fd is not open) {
            reopen fd
        }
        if (fd is open) {
            err = devctl(..., &status);
            if (err == EOK) {
                if (status == IPC_REPLY_ACK) {
                    return IPC_OK;
                }
            }
        }
        sleep (retry_period);
    }
    return IPC_TIMEOUT;
}


