// The following retry feature is preferrable
//   retry_time should be per destination port (in port_info), not per message
//
ipc_tx_timer_wakeup()
{
    for all messages on tx_que {
        if (this is next seq_num to send && message retry time has reached) {
            if (server not connected) {
                re-connect server;
            }
            err = devctl(DCMD_IPC_MSG, msg_buf, &status);
            if (err == OK) {
                if (status == IPC_REPLY_NONE) {
                    dequeue the message from tx_que;
                    if (tx_que is empty) {
                        disarm retry_timer;
                    }

                    if (message is blocked send) {
                        message->error_code = status;
                        sleepon_signal(message->error_code);
                    } else {
                        invoke notification callback;
                    }
                }

            } else {
                if (retry_count > MAX_RETRY_COUNT) {
                    drop message from tx_que;

                    if (message is blocked send) {
                        message->error_code = IPC_TIMEOUT;
                        sleepon_signal(message->error_code);
                    } else {
                        invoke notification callback;
                    }

                } else {
                    update retry time for the destination port
                }
            }
        }
    }
}

