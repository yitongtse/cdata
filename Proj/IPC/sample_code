Server operations
-----------------

Port creation:
    ipc_create_named_port(my_port_name, &my_port_id, port_flags,
                          rx_method, context, ipc_rx_handler);

Port registration:
    ipc_register_port(my_port_id);

Port removal:
    ipc_remove_port(my_port_id);



Client oerations
----------------

Port open:
    dest_port_info->port_features = IPC_PORT_FEAT_RELIABLE;
    ipc_open_port_by_name(dest_port_name, &dest_port_info);

Port close:
    ipc_close_port(dest_port_info);



Message operations
------------------

Client message blocked / non-blocked send:
    msg = ipc_get_pak_message(len, &dest_port_info, msg_type);
    // set up message body here
    error = ipc_send_message(msg, &dest_port_info);
//  error = ipc_send_message(msg, &dest_port_info);
    ipc_return_message(msg);


Client RPC blocked / non-blocked send:

    ipc_message *s_msg;
    ipc_message *r_msg;

    s_msg = ipc_get_pak_message(s_len, &dest_port_info, msg_type);
    // set up source message body here
    r_msg = ipc_send_rpc_blocked(&dest_port_info, smsg, &error);
//  error = ipc_send_rpc(&dest_port_info, s_msg);
    ipc_return_message(s_msg);


Server IPC reply:
    r_msg = ipc_get_pak_message(r_len, 0, 0);
    // Set up reply message body here
    error = ipc_send_rpc_reply_blocked(s_msg, r_msg);
//  error = ipc_send_rpc_reply(s_msg, r_msg);
    ipc_return_message(r_msg);

