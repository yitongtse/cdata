typedef unicast_map_entry_ {
    uint16 session_id;
} unicast_map_entry;

unicast_map_entry unicast_map[65536];

typedef multicast_map_entry_ {
    ip_addr_t src_ip;
    ip_addr_t dst_ip;
    uint16    session_id;
} multicast_map_entry;

multicast_map_entry multicast_map[NUM_MULTICAST_ENTRIES];



Pseudo code for video data packet handling:
  if (dest IP is multicast) {
      look up input session from multicast session map
  } else {
      look up input session from unicast session map
  }

