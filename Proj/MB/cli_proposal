// Video session configuration
config t
video-session-map

// Various session input types
session <id> udp <dst_udp> ...              ; unicast session
session <id> asm <dst_ip> ...               ; ASM multicast session
session <id> ssm <src_ip> <dst_ip> ...      ; SSM multicast session
session <id> udp <dst_udp> rtp ...          ; unicast session over RTP

// various session modes
session <id> ... [spts] ...                 ; spts mux (default)
session <id> ... mpts passthru ...          ; passthru
// session <id> ... mpts remux ...             ; MPTS remux
session <id> ... inject {default-add | default-drop} ... ; data injection

// bitrate allocation
session <id> ... [bitrate <bps>]


// Linecard configuration
//
config t
cable <slot>

video ip <ip-addr> qam-group <qam-grp> {static | dynamic} 
video 24-qam-map ip <ip_addr> qam-group <qam-grp>
video 48-qam-map ip <ip_addr>
video 192-qam-map ip <ip_addr> udp-group <udp-grp>
video qam-port all
video qam-port <start_qam_port> <end_qam_port>


// QAM sub-interface configuration
//
config t
int qam<slot>/<rf-port>.<qam-chan>

// SPTS session
video session <id> program <prog_num>

// Passthru session
video session <id>

// MPTS remux session (default include all programs)
video session <id>                            ; include all programs by default
video session <id> drop-all                   ; drop all program by default

video session <id> program in <in_prog_num> out <out_prog_num>
                                              ; specify in/out program mapping

video session <id> drop program <in_prog_num> ; drop specified program


// PID insertion (ghost PID)
video session <id> pid in <in_pid> out <out_pid>

// PID filtering
video session <id> drop pid <in_pid>

// Short cut configs
int q3/3.1
video udp <udp> program <num>
video sessions <cnt> udp-start <udp> upd-inc <inc> start-prog <num>
