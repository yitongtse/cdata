# Linecard configuration
#   A line card is divided into two qam groups:
#     qam-group 0: qam channels 0 to 23
#     qam-group 1: qam channels 24 to 47
#   Unique IP address is assigned for each qam group.
#
#   Each qam group can operate in one of the following modes:
#     - static configuration
#       - with default port map (24-qam even port)
#       - with user defined map set up by CLI, SNMP or GUI tool
#     - dynamic signaling
#       - GQI 
#       - NGOD R6
#
#   Q: Is qam group granularity enough??
#      How about QAM sharing between DEPI and video?  Do we need granularity
#      finer than qam group level?
#
config t
cable <slot>

# Configure a qam group for static configuration
[no] video static qam-group <grp> ip <dst_ip>

# Configure a qam group to use the default port map
[no] video default qam-group <grp> ip <dst_ip>

# Configure a qam group for dynamic signalling
[no] video dynamic qam-group <grp> ip <dst_ip>




# Video session configuration
#   id: session ID, 0 to 65535
#
config t
video-session

# Unicast sessions
[no] session <id> udp <dst_udp> [rtp] ...

# ASM multicast sessions
[no] session <id> asm dest-ip <dst_ip> [rtp] ...

# SSM multicast sessions
[no] session <id> ssm source-ip <src_ip> dest-ip <dst_ip> [rtp] ...

# SPTS Muxing (PSI snooping, pcr-correct, pid-remap)
[no] session <id> ... spts [bitrate <bps>]

# Passthru (PSI snooping, pcr-correct)
[no] session <id> ... passthru [bitrate <bps>]

# Data piping
[no] session <id> ... data [bitrate <bps>]




# QAM configuration
#   slot:     3 - 12
#   rf_port:  0 - 12
#   qam_chan: 0        for 1:1 stacking
#             0 - 1    for 1:2 stacking
#             0 - 3    for 1:4 stacking
#
config t
int qam<slot>/<rf_port>.<qam_chan>

# Single VOD session
[no] video udp <dst_udp> program <prog_num>

# A group of VOD session
[no] video count <session_cnt> udp <start_udp> increment <udp_incr> \
           program <start_prog_num>

# SPTS mux session
[no] video session <id> program <prog_num>

# Passthru or data piping session
[no] video session <id>

# PID filtering
[no] video session <id> pid drop <pid>

# PID add / custom remapping
[no] video session <id> pid remap <in_pid> <out_pid>

# Dejitter latency
[no] video jitter <ms>
[no] video session <id> jitter <ms>

# PAT interval
[no] video pat-interval <ms>

# PMT interval
[no] video session <id> pmt-interval <ms>



# Show commands
show video slot <slot_num>
show video session <id>
show video session <id> psi

show int qam<slot>/<rf_port>.<qam_chan> video
show int qam<slot>/<rf_port>.<qam_chan> video session <id>
show int qam<slot>/<rf_port>.<qam_chan> video session <id>


