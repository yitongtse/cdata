Clock Recovery with PCR jitter filtering (CBR model):

    pcr_inc = pcr_in - prev_pcr_in
    tp_itvl = pcr_in / pcr_tp_idx_inc
    flt_tp_itvl = filter(tp_itvl)
    flt_pcr_inc = flt_tp_itvl * pcr_tp_idx_inc

    drift = freq_adj * flt_pcr_inc
    pcr_out_time += flt_pcr_inc - drift
    adj_pcr_in = prev_pcr_in + flt_pcr_inc

