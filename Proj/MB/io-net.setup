# MB 5

# EOBC port
mount -T io-net -o mac=020000000500,tsec_index=2,duplex=0,speed=100 devn-mpc85xx-mossbeach.so
mount -T io-net /proc/boot/npm-tcpip.so
ifconfig en0 172.10.10.5 netmask 255.255.0.0

# 1st Internal GE port
mount -T io-net -o mac=020000000501 -o tsec_index=0,promiscuous,duplex=1,speed=1000 devn-mpc85xx-mossbeach.so
ifconfig en1 3.0.0.1 netmask 255.255.0.0

# 2nd Internal GE port
mount -T io-net -o mac=020000000502 -o tsec_index=1,promiscuous,duplex=1,speed=1000 devn-mpc85xx-mossbeach.so
ifconfig en2 4.0.0.1 netmask 255.255.0.0

