The following sturctures are used for resource allocation support:

// For in config
    resource_t *in_session_res;      	// points to calloced array of resource
    pool_t in_session_pool;      	// pool to maintain free resource
    que_elem_t in_session_list;  	// que to maintain used resourced
    in_config_t *in_session_config; 	// points to calloced array of config


// For carousel
    resource_t *crsl_res;
    pool_t crsl_pool;
    que_elem_t crsl_list;
    crsl_t *crsl;

// For carousel insert
    pool_t crsl_insert_pool;		// pool to maintain free insert
                                        // pool elements are insert, not res!
    que_elem_t crsl_insert_list;	// used insert sorted by qam channels

    // No insert resource array, and insert array, because inserts
    // are never referenced by an id!

