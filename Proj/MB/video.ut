# Typical test 1 (480 input sessions, 3.75 Mbps)

# Unicast Input
video provision 0 0 5.1.0.1
video add in udp 0 5.1.0.1 40000-40239
video provision 1 0 5.2.0.1
video add in udp 1 5.2.0.1 40000-40239

# Multicast Input
video add in ssm 1.0.0.1-1.0.0.253 224.1.0.1
video add in ssm 2.0.0.1-2.0.0.253 224.2.0.1

# Output
video add out 0-239 0-23 1-10
video add out 240-479 24-47 1-10

# Carousels
# Assumes 5 carousels per QAM, each with 2 TPs, once every 100 ms
video add carousel 2
video add carousel 2
video add carousel 2
video add carousel 2
video add carousel 2
video add carousel insert 0 0-47 -1 4500
video add carousel insert 1 0-47 -1 4500
video add carousel insert 2 0-47 -1 4500
video add carousel insert 3 0-47 -1 4500
video add carousel insert 4 0-47 -1 4500



# Typical test 2 (760 input sessions, 2.5 Mbps)

# Unicast Input
video provision 0 0 5.1.0.1
video add in udp 0 5.1.0.1 40000-40379
video provision 1 0 5.2.0.1
video add in udp 1 5.2.0.1 40000-40379

# Multicast Input
video add in ssm 1.0.0.1-1.0.1.124 224.1.0.1
video add in ssm 2.0.0.1-2.0.1.124 224.2.0.1

# Output
video add out 0-379 0-23 1-16
video add out 380-759 24-47 1-16



# Stress test (1440 input/output sessions configured, 760 active)

# Unicast Input
video provision 0 0 5.1.0.1
video add in udp 0 5.1.0.1 40000-40719
video provision 1 0 5.2.0.1
video add in udp 1 5.2.0.1 40000-40719

# Multicast Input
video add in ssm 1.0.0.1-1.0.2.208 224.1.0.1
video add in ssm 2.0.0.1-2.0.2.208 224.2.0.1

# Output
video add out 0-719 0-23 1-30
video add out 720-1439 24-47 1-30

===========================================================

# Set up using DevTest's streams

video provision 0 0 192.168.100.10
video add in udp 0 192.168.100.10 49152-49161
video add out 0-9 0 1-10

===========================================================

video provision 0 0 5.1.0.1
video add in udp 0 5.1.0.1 40000
video add out 0 0 1-30

video delete out 0-29

==============================================================

# Carousel insert test

video add carousel 2
video add carousel insert 0 0 -1 45000
video query carousel 0

