# Unicast Remap session
video add in 1 udp 0 192.168.30.10 49152
video add out 1 1 0 1

# Multicast session
video add in 2 ssm 0 1.1.1.1 224.0.0.1
video add out 2 2 0 2

# Passthru session
video add in 3 udp 0 192.168.30.10 49153 passthru
video add out 3 3 1

# Data piping session
video add in 4 udp 0 192.168.30.10 49154 inject
video add out 4 4 2


# Modify input session
video modify in 1 bitrate 4000000
video modify in 1 jitter 100
video modify in 1 idle 100
video modify in 1 off 10

video modify in 1 unicast 0 192.168.30.10 49162
video modify in 2 ssm 0 2.2.2.2 224.0.0.1

