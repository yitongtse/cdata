Order of access

in_session_t:

process_ip_pkt()
  *state
  *src_ip
  (src_ip_change_cnt)
  *tp_info_idx (currently for prefetching only)
  (drop_ip_cnt)
  (stat.idle_cnt)
  (prev_tp_arvl)
  (stat.idle_time)
  (flags)
  *prev_tp_arvl
  *stat.ip_cnt
  *stat.tp_cnt
  *tp_info_idx
  *tp_info_buf[]

process_in_tp()
  *tp_idx
  (stat.sync_loss_cnt)
  stat.null_tp_cnt
  tp_info_usage_id
  flags
  (disc_flag)
  (stat.disc_cnt)
  pid_tab
  (stat.unref_tp_cnt)
  (master_pcr_pid)
  (prev_pcr_tpinfo_idx)
  (stat.cc_err_cnt)
  cfg->input_port

  // Non-PCR TP
  stat.non_pcr_tp_cnt

