in_session summary:
  state
  src_ip
  prev_tp_arvl
  stat.ip_cnt
      .tp_cnt
      .null_tp_cnt
  tp_info_idx
  tp_info_buf[]
  tp_idx
  tp_info_usage_id
  flags
  pid_tab



out_session_t:

process_qam_channel()
  state

process_out_session()
  qam_id
  in_ses->cfg.pid_remap_flag, parse_psi_flag, dejitter_flag, mpts_flag
  (prog_list, out_prog->pmt_built, ...)

process_out_tp()
  tp_idx
  out_time
  tp_itvl
  adj_out_time
  out_time
  stat.non_pcr_tp_cnt
  stat.non_pcr_tp_cnt



