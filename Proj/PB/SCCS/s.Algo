Dejittering:
    arvl_time_inc = arvl_time - prev_arvl_time
    tp_idx_inc = tp_idx - prev_tp_idx
    in_tpi = arvl_time_inc / tp_idx_inc
    dj_tpi = iir_filter(in_tpi)
    dj_arvl_time += dj_tpi * tp_idx_inc

Prediction:
    pcr_inc = pcr_time - prev_pcr_time
    tbo_drift = pcr_inc * reg_freq_adj
    est_tbo += tbo_drift

Forward path:
    in_tbo = pcr_time - dj_arvl_time
    err_tbo = in_tbo - est_tbo
    norm_err_tbo = err_tbo / pcr_inc
    filt_tbo = loop_filter(norm_err_tbo)
    freq_adj = loop_gain * filt_tbo
    reg_freq_adj = clamp(freq_adj)

Delivery time:
    out_inc = pcr_inc - tbo_drift
    out_time += out_inc
    out_tpi = out_inc / pcr_tp_idx_inc

PCR correction:
    tbo = est_tbo


Non-PCR TP processiong
    tp_idx_inc = tp_idx - prev_tp_idx
    out_time += out_tpi * tp_idx_inc

