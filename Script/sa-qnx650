#! /bin/csh

setenv QNX_CONFIGURATION /auto/vwsnmq/qnxlicenses
setenv QNXLM_LICENSE_FILE 27000@friday.cisco.com:@dechen-ultra5.cisco.com
setenv QNX_TARGET /auto/vwsnmq/qnx650/target/qnx6
setenv QNX_HOST /auto/vwsnmq/qnx650/host/linux/x86
setenv QCONFIG $QNX_TARGET/usr/include/qconfig.mk
setenv SES_STATIC_ENV MISC
setenv SESTOOLS_NO_SESCPP 1

set comp = "/auto/vwsnmq/qnx650_sp1/host/linux/x86/usr/bin/qcc -V gcc_ntoppcbe -DCOMPONENT_BUILD -DPARENT_COMPONENT=rfgw -D__QNX__ -DTARGET_CISCO -DOBJECT_8500 -DBUGTRACE=1 -DLOGGER=1 -DBUGINF=1 -DERRMSG=1 -DTRACE=1 -DBENCH_PPC -DCACHE_SIZE=64 -DCLI=1 -DDEBUG_QUE=1 -DDEBUG_MUTEX=1 -DIPC_SIM_ERR=0 -DNUM_INPUT_PORTS=2 -DNUM_QAMS=384 -DSES_HASH_SLOTS=7681 -DPROG_HASH_SLOTS=7681 -DPID_HASH_SLOTS=61441 -DFLOWS_PER_QAM=32 -DOUTCMDS_PER_FLOW=1024 -DMIN_LATENCY=50 -DMAX_JITTER=300 -DBUF_HEADROOM=25 -DPAST_SCH_WIN=30 -DOUT_WIN_SIZE_MS=30 -DVIDEO_DIAG=1 -DENABLE_FPGA=0 -DCA_SUPPORT=1 -DMAX_CA_SESSIONS=3840 -DECM_INSERT_CNT=7680 -DDEBUG_FP_MATH=0 -DSW_MUX=0 -DDEBUG_OUTCMD=1  -I../../../../../../cisco.comp -I/auto/vwsnmq/qnx650_sp1/target/qnx6/usr/include  -I../../../../../../ios/sys/h -I/auto/vwsnmq/qnx650_sp1/target/qnx6/usr/include -I/auto/vwsnmq/qnx650_sp1/target/qnx6/usr/include/io-pkt -I../../../../../../cisco.comp/rfgw/lc/ds384/src/enc/framework -I../../../../../../cisco.comp/rfgw/lc/ds384/src/enc/root      -Wall -Wno-main -Wpointer-arith -Wstrict-prototypes -Wformat -Werror -O2 -DDS384_LC -g2 -Wno-strict-prototypes -c -Wp,-MD"

/auto/ses/bin/sacc -nonios -compiler $comp -no_sescpp -f $1

