#!/usr/cisco/bin/perl5.8 -w
########################################################################
#  Copyright (c) 2001-2005 by cisco Systems, Inc.
#  All Rights Reserved
#  Eugenio Dols
#
########################################################################
=head1 NAME

snaps - Make symbolic links to snaps directories cscope, tags and ID files

=head1 SYNOPSIS

B<snaps> S<[ B<-h> ]>
         S<[ B<-r> ]>
         S<[ B<-b> I<branch> ]>

=head1 OPTIONS
    -a      - Remove existing links and/or files and then create them. This is
              equivalent to running snaps with -r option followed by snaps
    -h      - Display usage help.
    -r      - Remove existing links and/or files.
    -b      - Specify the snapshot branch to be used instead of using
              the integration branch as determined by the script.


=head1 DESCRIPTION

This tool is used to create symbolic links to the snapshot cscope/tags/ID files
created nightly on /auto/ios-snaps.
In order for this tool to work properly one should be inside /vob/ios directory
when executing this script.

=head1 EXAMPLES
1. Make the links to the integration branch where this view belongs
snaps
2. To remove current links or files
snaps -r
3. To create the links to a particular branch different than the integration
   branch
snaps -b geo_cable

=cut

######################################################################
#                    MODULES                                         #
######################################################################
BEGIN
{
    $ENV{ CC_LIBDIR } = ( $^O eq 'MSWin32' ) ? 't:/cctools/current/lib':
                                               '/usr/cisco/lib/atria/perl'
        unless( exists( $ENV{ CC_LIBDIR } ) );
    $ENV{ CC_ALEDIR } = ( $^O eq 'MSWin32' ) ? 't:/ale/current/lib':
                                         '/usr/cisco/packages/ale/current/lib'
        unless( exists( $ENV{ CC_ALEDIR } ) );
}

use strict;
use lib ( $ENV{ CC_LIBDIR }, $ENV{ CC_ALEDIR } );
use Getopt::Long;
use cc_vobgrp;
use cc_view;
use cc_error;

######################################################################
#                              GLOBALS
######################################################################
my $View;        # cc_view object associated with the current view.
my $ScriptName = &cc_basename($0);
my $gigi_branch = 0;

#-------------------------------------------------------------------------------
# show_usage
#    prints out usage.
# Params:
#    none.
# Return:
#    none.
#-------------------------------------------------------------------------------

sub show_usage
{
    print( <<EOF );

Usage:

$ScriptName -h

$ScriptName [-a] [-b <branch>] [-r]

   -a                 Remove existing links and files and then create them

   -b <branch>        Create the links to this branch.
   
   -r                 Remove existing symbolic links or same named files

EOF
}

sub remove_files
{
    print("Removing links... ");
    unlink("/vob/ios/cscope.out");
    unlink("/vob/ios/cscope.in.out");
    unlink("/vob/ios/cscope.out.in");
    unlink("/vob/ios/cscope.out.po");
    unlink("/vob/ios/cscope.po.out");
    unlink("/vob/ios/cisco.comp");

    unlink("/vob/ios/sys/cscope.out");
    unlink("/vob/ios/sys/cscope.in.out");
    unlink("/vob/ios/sys/cscope.po.out");
    unlink("/vob/ios/sys/tags");
    unlink("/vob/ios/sys/TAGS");
    unlink("/vob/ios/sys/ID");
    print("Done\n");
}

######################################################################
#                                MAIN
######################################################################
$ENV{'CC_DISABLE_TRIGS'} = 'chkview_mkbranch_co_preop.perl checkout_postop.perl';
try
{
    my $integ_branch_name;
    my(@options);
    my $branch_path;

    #-----------------------------------------------------------------
    # process options.
    #-----------------------------------------------------------------
    
    use vars qw( $opt_a $opt_h $opt_b $opt_r);
    @options = qw( a h b=s r);
    
    if ( !GetOptions(@options) ) {
	warn("$ScriptName: invalid arguments passed.\n");
	&show_usage;
	exit(1);
    }
    
    if ($opt_h) {
	&show_usage;
	exit(0);
    }

    if ($opt_r) {
	&remove_files;
	exit(0);
    }

    if ($opt_a) {
	&remove_files;
    }

    if ($opt_b) {
	$integ_branch_name = $opt_b;
    } else {
	$View = new cc_view()
	    or die( cc_view->err_retrieve(),
		   "ERROR: Please set to a view before running this command.\n" );
	
	my $integ_branch = $View->get_integ_branch();
	$integ_branch_name = $integ_branch->get_name()
	    or die( 'integ_branch_name:',
		   $integ_branch->err_retrieve );
    }
	
    if (! -d  "/auto/ios-snaps/$integ_branch_name.snap") {
	print("The directory /auto/ios-snaps/$integ_branch_name.snap does not exist, exiting without creating links. \n");
	exit(1);
    }

    if ( -e  "/auto/ios-snaps/$integ_branch_name.snap/ios/cscope.out") {
	$gigi_branch = 1;
    }
    
    if ($gigi_branch) {
	$branch_path = "$integ_branch_name.snap/ios";
    } else {
	$branch_path = "$integ_branch_name.snap";
    }

    print("Creating links... ");
    
    system( "/bin/ln -s /auto/ios-snaps/$branch_path/cscope.out /vob/ios/cscope.out" );
    system( "/bin/ln -s /auto/ios-snaps/$branch_path/cscope.in.out /vob/ios/cscope.in.out" );
    system( "/bin/ln -s /auto/ios-snaps/$branch_path/cscope.out.in /vob/ios/cscope.out.in" );
    system( "/bin/ln -s /auto/ios-snaps/$branch_path/cscope.out.po /vob/ios/cscope.out.po" );
    system( "/bin/ln -s /auto/ios-snaps/$branch_path/cscope.po.out /vob/ios/cscope.po.out" );
    system( "/bin/ln -s /auto/ios-snaps/$branch_path/cisco.comp /vob/ios/cisco.comp" );

    system( "/bin/ln -s /auto/ios-snaps/$branch_path/sys/cscope.out /vob/ios/sys/cscope.out" );
    system( "/bin/ln -s /auto/ios-snaps/$branch_path/sys/cscope.in.out /vob/ios/sys/cscope.in.out" );
    system( "/bin/ln -s /auto/ios-snaps/$branch_path/sys/cscope.po.out /vob/ios/sys/cscope.po.out" );
    system( "/bin/ln -s /auto/ios-snaps/$branch_path/sys/tags /vob/ios/sys/tags" );
    system( "/bin/ln -s /auto/ios-snaps/$branch_path/sys/TAGS /vob/ios/sys/TAGS" );
    system( "/bin/ln -s /auto/ios-snaps/$branch_path/sys/ID /vob/ios/sys/ID" );
   
    print("Done\n");
}
otherwise
{
    my $e = shift;
    throw cc_error( "BUG: Error running script: ",
		   $e->stringify );
};

