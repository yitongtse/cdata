  ************************************************
  Enhanced time stamp regeneration:
    For B Pic:
        DTS = PTS = prevDET

        curDI += DI
        DET = PET = DTS + (curDI>>4)
        curDI &= 0xF

        last in anchor unit: anchor PTS = DET

    For I/P pic:
        DTS = prevDET

        curDI += prevRefDI
        DET = DTS + (curDI>>4);
        curDI &= 0xF;
        prevRefDI = DI;

        closing: PTS = DET

    For Glue pic:
        DTS = prevDET

        curDI += prevRefDI
        DET = DTS + (curDI>>4)
        curDI &= 0xF
        prevRefDI = DI
        PTS = DET
  ************************************************


